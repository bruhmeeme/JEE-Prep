    {
      "name": "usernames",
      "description": "Lookup table from username to email/uid.",
      "securityRules": {
         "read": "true",
         "create": "true",
         "update": "request.auth != null && request.auth.uid == data.uid",
         "delete": "request.auth != null && request.auth.uid == data.uid"
      }
    },
